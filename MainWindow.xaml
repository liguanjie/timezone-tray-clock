<Window x:Class="TimezoneTrayClock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timezone Tray Clock"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Activated="Window_Activated"
        Closing="Window_Closing"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseWheel="Window_MouseWheel"
        KeyDown="Window_KeyDown">
    <Border CornerRadius="11"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            Padding="10,6">
        <Border.LayoutTransform>
            <ScaleTransform x:Name="RootScaleTransform" ScaleX="1" ScaleY="1" />
        </Border.LayoutTransform>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource BgGradientStart}" Offset="0" />
                <GradientStop Color="{DynamicResource BgGradientEnd}" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="14"
                              ShadowDepth="2"
                              Color="{DynamicResource ShadowColor}"
                              Opacity="1" />
        </Border.Effect>

        <Grid Background="Transparent">
            <Border Margin="5"
                    CornerRadius="8"
                    Background="{DynamicResource InnerBorderBg}"
                    BorderBrush="{DynamicResource InnerBorderBrush}"
                    BorderThickness="1" />

            <StackPanel MinWidth="78"
                        MinHeight="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="TimeTextBlock"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="22:52:03"
                           Foreground="{DynamicResource TimeTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Typography.NumeralAlignment="Tabular"
                           TextOptions.TextFormattingMode="Display"
                           TextOptions.TextRenderingMode="ClearType" />
                <TextBlock x:Name="DateTextBlock"
                           Margin="0,1,0,0"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="2026/4/22"
                           Foreground="{DynamicResource DateTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="Normal"
                           Typography.NumeralAlignment="Tabular"
                           TextOptions.TextFormattingMode="Display"
                           TextOptions.TextRenderingMode="ClearType" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
