<Window x:Class="TimezoneTrayClock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timezone Tray Clock"
        Width="98"
        Height="42"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Activated="Window_Activated"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Width="98"
            Height="42"
            CornerRadius="11"
            BorderBrush="#20FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F7F6F3" Offset="0" />
                <GradientStop Color="#EEE9E3" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="14"
                              ShadowDepth="2"
                              Color="#120F0F0F"
                              Opacity="1" />
        </Border.Effect>

        <Grid Background="Transparent">
            <Border Margin="5"
                    CornerRadius="8"
                    Background="#10FFFFFF"
                    BorderBrush="#0AFFFFFF"
                    BorderThickness="1" />

            <StackPanel Width="78"
                        Height="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="TimeTextBlock"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="22:52:03"
                           Foreground="#171717"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextOptions.TextFormattingMode="Display"
                           TextOptions.TextRenderingMode="ClearType" />
                <TextBlock x:Name="DateTextBlock"
                           Margin="0,1,0,0"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="2026/4/22"
                           Foreground="#7A756F"
                           FontFamily="Segoe UI"
                           FontSize="9"
                           FontWeight="Normal"
                           TextOptions.TextFormattingMode="Display"
                           TextOptions.TextRenderingMode="ClearType" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
