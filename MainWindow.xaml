<Window x:Class="TimezoneTrayClock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timezone Tray Clock"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Activated="Window_Activated"
        Closing="Window_Closing"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseWheel="Window_MouseWheel"
        KeyDown="Window_KeyDown">
    <Border x:Name="RootBorder"
            CornerRadius="10"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            Padding="10,5">
        <Border.LayoutTransform>
            <ScaleTransform x:Name="RootScaleTransform" ScaleX="{Binding Settings.Scale}" ScaleY="{Binding Settings.Scale}" />
        </Border.LayoutTransform>
        <Border.Background>
            <Binding Path="BackgroundBrush" />
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="6"
                              ShadowDepth="1"
                              Direction="270"
                              Color="{DynamicResource ShadowColor}"
                              Opacity="0.4" />
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock x:Name="TimeTextBlock"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding TimeText}"
                       Foreground="{DynamicResource TimeTextBrush}"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       FontSize="14"
                       FontWeight="Normal"
                       Typography.NumeralAlignment="Tabular"
                       TextOptions.TextFormattingMode="Display"
                       TextOptions.TextRenderingMode="ClearType" />
            <TextBlock x:Name="DateTextBlock"
                       Margin="0,-2,0,0"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding DateText}"
                       Foreground="{DynamicResource DateTextBrush}"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="11"
                       FontWeight="Normal"
                       Typography.NumeralAlignment="Tabular"
                       TextOptions.TextFormattingMode="Display"
                       TextOptions.TextRenderingMode="ClearType" />
        </StackPanel>
    </Border>
</Window>
